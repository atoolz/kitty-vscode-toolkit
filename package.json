{
  "name": "kitty-vscode-toolkit",
  "displayName": "Kitty Toolkit",
  "description": "Complete Kitty terminal toolkit: syntax highlighting, IntelliSense, validation, and documentation for kitty.conf configuration",
  "version": "0.1.1",
  "publisher": "atoolz",
  "author": {
    "name": "Andre Ahlert"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/atoolz/kitty-vscode-toolkit"
  },
  "bugs": {
    "url": "https://github.com/atoolz/kitty-vscode-toolkit/issues"
  },
  "homepage": "https://github.com/atoolz/kitty-vscode-toolkit#readme",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters"
  ],
  "keywords": [
    "kitty",
    "terminal",
    "config",
    "gpu",
    "emulator",
    "theme"
  ],
  "activationEvents": [
    "onLanguage:kitty",
    "workspaceContains:**/kitty.conf",
    "workspaceContains:**/kitty/*.conf"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "kitty",
        "aliases": ["Kitty Config", "kitty"],
        "extensions": [".conf"],
        "filenames": ["kitty.conf"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kitty",
        "scopeName": "source.kitty",
        "path": "./syntaxes/kitty.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "kitty",
        "path": "./snippets/kitty.json"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "tsc --noEmit",
    "package": "vsce package",
    "prepublish": "npm run build",
    "test:e2e": "tsc -p ./tsconfig.test.json && node ./dist/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.20.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.3.0"
  }
}
