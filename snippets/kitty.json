{
  "Kitty Starter Config": {
    "prefix": "kitty-starter",
    "body": [
      "# Kitty Terminal Configuration",
      "# https://sw.kovidgoyal.net/kitty/conf/",
      "",
      "# Fonts",
      "font_family      ${1:monospace}",
      "bold_font        auto",
      "italic_font      auto",
      "bold_italic_font auto",
      "font_size        ${2:11.0}",
      "",
      "# Cursor",
      "cursor_shape ${3|block,beam,underline|}",
      "",
      "# Scrollback",
      "scrollback_lines ${4:2000}",
      "",
      "# Mouse",
      "mouse_hide_wait ${5:3.0}",
      "detect_urls     yes",
      "",
      "# Terminal Bell",
      "enable_audio_bell ${6|yes,no|}",
      "",
      "# Window",
      "remember_window_size  yes",
      "window_padding_width  ${7:0}",
      "",
      "# Colors",
      "foreground ${8:#dddddd}",
      "background ${9:#000000}",
      "background_opacity ${10:1.0}",
      "",
      "# Shell",
      "shell .",
      "term  xterm-kitty",
      "$0"
    ],
    "description": "Basic kitty.conf starter template"
  },
  "Kitty Font Configuration": {
    "prefix": "kitty-fonts",
    "body": [
      "# Font Configuration",
      "font_family      ${1:FiraCode Nerd Font}",
      "bold_font        ${2:auto}",
      "italic_font      ${3:auto}",
      "bold_italic_font ${4:auto}",
      "font_size        ${5:12.0}",
      "disable_ligatures ${6|never,cursor,always|}",
      "$0"
    ],
    "description": "Font configuration block"
  },
  "Kitty Color Scheme": {
    "prefix": "kitty-colors",
    "body": [
      "# Color Scheme",
      "foreground           ${1:#dddddd}",
      "background           ${2:#000000}",
      "selection_foreground ${3:#000000}",
      "selection_background ${4:#fffacd}",
      "background_opacity   ${5:1.0}",
      "",
      "# Normal colors (0-7)",
      "color0  ${6:#000000}",
      "color1  ${7:#cc0403}",
      "color2  ${8:#19cb00}",
      "color3  ${9:#cecb00}",
      "color4  ${10:#0d73cc}",
      "color5  ${11:#cb1ed1}",
      "color6  ${12:#0dcdcd}",
      "color7  ${13:#dddddd}",
      "",
      "# Bright colors (8-15)",
      "color8  ${14:#767676}",
      "color9  ${15:#f2201f}",
      "color10 ${16:#23fd00}",
      "color11 ${17:#fffd00}",
      "color12 ${18:#1a8fff}",
      "color13 ${19:#fd28ff}",
      "color14 ${20:#14ffff}",
      "color15 ${21:#ffffff}",
      "$0"
    ],
    "description": "Color scheme configuration"
  },
  "Kitty Keybindings": {
    "prefix": "kitty-keybinds",
    "body": [
      "# Keybindings",
      "map ctrl+shift+c copy_to_clipboard",
      "map ctrl+shift+v paste_from_clipboard",
      "",
      "# Scrollback",
      "map ctrl+shift+up   scroll_line_up",
      "map ctrl+shift+down scroll_line_down",
      "map ctrl+shift+page_up   scroll_page_up",
      "map ctrl+shift+page_down scroll_page_down",
      "map ctrl+shift+home scroll_home",
      "map ctrl+shift+end  scroll_end",
      "",
      "# Window management",
      "map ctrl+shift+enter new_window",
      "map ctrl+shift+w     close_window",
      "map ctrl+shift+]     next_window",
      "map ctrl+shift+[     previous_window",
      "",
      "# Tab management",
      "map ctrl+shift+t     new_tab",
      "map ctrl+shift+q     close_tab",
      "map ctrl+shift+right next_tab",
      "map ctrl+shift+left  previous_tab",
      "",
      "# Font size",
      "map ctrl+shift+equal  change_font_size all +2.0",
      "map ctrl+shift+minus  change_font_size all -2.0",
      "map ctrl+shift+backspace change_font_size all 0",
      "$0"
    ],
    "description": "Common keybinding configuration"
  },
  "Kitty Tab Bar": {
    "prefix": "kitty-tabs",
    "body": [
      "# Tab Bar",
      "tab_bar_edge    ${1|bottom,top|}",
      "tab_bar_style   ${2|fade,hidden,powerline,separator,slant,custom|}",
      "tab_bar_align   ${3|left,center,right|}",
      "tab_bar_min_tabs ${4:2}",
      "tab_switch_strategy ${5|previous,left,right,last|}",
      "tab_title_template {fmt.fg.red}{bell_symbol}{activity_symbol}{fmt.fg.tab}{title}",
      "$0"
    ],
    "description": "Tab bar configuration"
  },
  "Kitty Window Layout": {
    "prefix": "kitty-window",
    "body": [
      "# Window Layout",
      "remember_window_size    ${1|yes,no|}",
      "initial_window_width    ${2:640}",
      "initial_window_height   ${3:400}",
      "window_border_width     ${4:0.5pt}",
      "window_margin_width     ${5:0}",
      "window_padding_width    ${6:0}",
      "active_border_color     ${7:#00ff00}",
      "inactive_border_color   ${8:#cccccc}",
      "placement_strategy      ${9|center,top-left|}",
      "hide_window_decorations ${10|no,yes,titlebar-only|}",
      "confirm_os_window_close ${11:0}",
      "$0"
    ],
    "description": "Window layout configuration"
  }
}
